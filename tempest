#!/usr/bin/env php
<?php

if (($argv[1] ?? null) === 'data:parse') {
    gc_disable();
    $input = null;
    $output = null;
    foreach ($argv as $arg) {
        if (str_starts_with($arg, '--inputPath=')) $input = substr($arg, 12);
        if (str_starts_with($arg, '--outputPath=')) $output = substr($arg, 13);
        if (str_starts_with($arg, '--input-path=')) $input = substr($arg, 13);
        if (str_starts_with($arg, '--output-path=')) $output = substr($arg, 14);
    }
    if (!$input || !$output) {
        fwrite(STDERR, "Usage: php tempest data:parse --inputPath=... --outputPath=...\n");
        exit(1);
    }
    require __DIR__ . '/app/Commands/Visit.php';
    require __DIR__ . '/app/Parser.php';
    \App\Parser::parse($input, $output);
    exit(0);
}

use Tempest\Console\ConsoleApplication;

require_once getcwd() . '/vendor/autoload.php';

ConsoleApplication::boot(loadBuiltInCommands: false)->run();

exit;
