#!/usr/bin/env php
<?php

if (isset($argv[1]) && $argv[1] === 'data:parse') {
    $input  = $argv[2] ?? 'data/data.csv';
    $output = $argv[3] ?? 'data/data.json';

    require_once 'app/Parser.php';
    App\Parser::parse($input, $output);
    exit(0);
}

require_once 'vendor/autoload.php';

\Tempest\Console\ConsoleApplication::boot(loadBuiltInCommands: false)->run();

exit;